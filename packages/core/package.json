{
  "name": "@artmsilva/seams-core",
  "version": "0.1.0",
  "description": "Isomorphic core API for Seams (no React dependency)",
  "keywords": [
    "css-in-js",
    "react-server-components",
    "rsc",
    "seams",
    "stitches",
    "styling"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/artmsilva/seams.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "csstype": "catalog:"
  },
  "devDependencies": {
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
