{
  "name": "@artmsilva/seams-next-plugin",
  "version": "0.1.0",
  "description": "Next.js integration for Seams",
  "keywords": [
    "css-in-js",
    "next-plugin",
    "nextjs",
    "rsc",
    "seams",
    "stitches"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/artmsilva/seams.git",
    "directory": "packages/next-plugin"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./loader": {
      "import": {
        "types": "./dist/loader.d.ts",
        "default": "./dist/loader.js"
      },
      "require": {
        "types": "./dist/loader.d.cts",
        "default": "./dist/loader.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@artmsilva/seams-plugin-common": "workspace:*"
  },
  "devDependencies": {
    "next": "^16.2.2",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "webpack": "^5.105.0"
  },
  "peerDependencies": {
    "next": "^14.0.0 || ^15.0.0 || ^16.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
