{
  "name": "@stitches-rsc/plugin-common",
  "version": "0.1.0",
  "description": "Shared build plugin logic for Stitches RSC",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/generator": "^7.29.0",
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@stitches-rsc/core": "workspace:*"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.0",
    "@types/babel__generator": "^7.6.0",
    "@types/babel__traverse": "^7.20.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stitches-rsc/stitches-rsc.git",
    "directory": "packages/plugin-common"
  },
  "keywords": ["css-in-js", "stitches", "rsc", "build-plugin", "css-extraction"]
}
