{
  "name": "@stitches-rsc/plugin-common",
  "version": "0.1.0",
  "description": "Shared build plugin logic for Stitches RSC",
  "keywords": [
    "build-plugin",
    "css-extraction",
    "css-in-js",
    "rsc",
    "stitches"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stitches-rsc/stitches-rsc.git",
    "directory": "packages/plugin-common"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/core": "catalog:",
    "@babel/generator": "catalog:",
    "@babel/parser": "catalog:",
    "@babel/traverse": "catalog:",
    "@babel/types": "catalog:",
    "@stitches-rsc/core": "workspace:*"
  },
  "devDependencies": {
    "@types/babel__core": "catalog:",
    "@types/babel__generator": "catalog:",
    "@types/babel__traverse": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
