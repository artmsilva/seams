{
  "name": "stitches-rsc",
  "version": "0.0.0",
  "private": true,
  "description": "Zero-runtime Stitches.js replacement for React Server Components",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "vp test",
    "test:run": "vp test run",
    "test:compat": "vp test run --project compat",
    "check": "vp check",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "typecheck": "tsc --build",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@babel/core": "catalog:",
    "@babel/generator": "catalog:",
    "@babel/parser": "catalog:",
    "@babel/traverse": "catalog:",
    "@babel/types": "catalog:",
    "@types/babel__core": "catalog:",
    "@types/babel__generator": "catalog:",
    "@types/babel__traverse": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "csstype": "catalog:",
    "react": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}
