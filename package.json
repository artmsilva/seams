{
  "name": "stitches-rsc",
  "private": true,
  "version": "0.0.0",
  "description": "Zero-runtime Stitches.js replacement for React Server Components",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "vitest",
    "test:run": "vitest run",
    "test:compat": "vitest run --project compat",
    "lint": "eslint packages/*/src",
    "typecheck": "tsc --build",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/generator": "^7.24.0",
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "@types/babel__core": "^7.20.0",
    "@types/babel__generator": "^7.6.0",
    "@types/babel__traverse": "^7.20.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "csstype": "^3.1.3",
    "eslint": "^10.0.2",
    "prettier": "^3.2.0",
    "react": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
